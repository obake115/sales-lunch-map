{
  "expo": {
    "name": "ランチマップ",
    "slug": "sales-lunch-map",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "saleslunchmap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "jp.kawashun.saleslunchmap",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "招待コードのQRを読み取るためにカメラを使用します。",
        "NSLocationWhenInUseUsageDescription": "現在地周辺の店舗表示および地図機能のために位置情報を使用します。",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "登録したお店の近くを通った時にリマインド通知を送るために、バックグラウンドでも位置情報を使用します。",
        "NSLocationAlwaysUsageDescription": "登録したお店の近くを通った時にリマインド通知を送るために、バックグラウンドでも位置情報を使用します。",
        "NSPhotoLibraryUsageDescription": "プロフィール写真を選択するために写真ライブラリへのアクセスを許可してください。",
        "NSPhotoLibraryAddUsageDescription": "プロフィール写真を保存するために写真ライブラリへのアクセスを許可してください。",
        "NSUserTrackingUsageDescription": "広告のパーソナライズのためにトラッキングの許可をお願いします。許可しなくてもアプリは利用できます。",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "jp.kawashun.saleslunchmap",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#E9E4DA"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "locales": {
      "en": "./locales/en-infoplist.json"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "プロフィール写真を選択するために写真ライブラリへのアクセスを許可してください。"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "招待コードのQRを読み取るためにカメラへのアクセスを許可してください。"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9492630687794560~7303765475",
          "iosAppId": "ca-app-pub-9492630687794560~6268195028"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-apple-authentication",
      "./plugins/withFixAppleAuthIPad",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.958181113602-b6t50op6b7u2s50avp3uou3njpm3ghqg"
        }
      ],
      "./plugins/withDisableAndroidTablet",
      "./plugins/withLunchMapWidget",
      "expo-tracking-transparency",
      [
        "expo-share-intent",
        {
          "iosShareExtensionName": "ShareLunchMap",
          "iosActivationRules": {
            "NSExtensionActivationSupportsImageWithMaxCount": 1
          }
        }
      ],
      "expo-localization",
      "expo-sharing",
      "expo-sqlite",
      "expo-web-browser"
    ],
    "cli": {
      "appVersionSource": "remote"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dcf2b66d-ff77-44d4-918a-2aae335a7281"
      }
    },
    "owner": "kawashun",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/dcf2b66d-ff77-44d4-918a-2aae335a7281"
    }
  }
}
